{
    "lr": 0.001,
    "batch_size": 30,
    "max_epochs": 90,
    "patience": 200,
    "min_delta": 0.01,
    "shuffle": true,
    "initialise_weights": true,
    "drop_last": true,
    "profile": true,
    "logg_cpu_utilization": true,
    "cpu_burst_batches": 5,
    "max_training_size": 30000,
    "max_validation_size": 100,
    "max_test_size": 1000,
    "model": {
        "name": "GCN",
        "args": {
            "in_dim": 1433,
            "hidden_dim1": 12,
            "hidden_dim2": 12,
            "nbr_classes": 7,
            "init_weights": null
        }
    },
    "sampler": {
        "name": "NeighborSampler",
        "num_neighbors": [
            10,
            5
        ]
    },
    "feature_store": "NoCacheFeatureStore",
    "graph_store": "Neo4jSingleGS",
    "dataset": "cora",
    "nodeloader_args": {
        "pickle_safe": false,
        "num_workers": 0,
        "prefetch_factor": 2,
        "filter_per_worker": false,
        "persistent_workers": false,
        "pin_memory": false,
        "shuffle": true
    }
}