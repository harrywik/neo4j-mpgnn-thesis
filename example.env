# Neo4j connection
URI=bolt://localhost:7687
USERNAME=neo4j
PASSWORD=your_password

# Neo4j plugin deployment (used by make build-plugin)
NEO4J_PLUGINS_DIR=/var/lib/neo4j/plugins

# GNN model artifact directory (must match server.jvm.additional=-DNEO4J_GNN_MODEL_DIR in neo4j.conf)
NEO4J_GNN_MODEL_DIR=/path/to/gnn_models
