{
  "_comment": "DEPRECATED — uses PageRankCacheFeatureStore and BaseLineGS from neo4j_pyg/deprecated/",
  "feature_store": {
    "class_name": "PageRankCacheFeatureStore",
    "connection_mode": "driver",
    "extra_kwargs": {
      "cache_size": 3000
    }
  },
  "graph_store": {
    "class_name": "BaseLineGS",
    "connection_mode": "driver"
  },
  "sampler": {
    "class_name": "UniformSampler",
    "num_neighbors": [10, 5]
  },
  "model": {
    "class_name": "GCN"
  },
  "trainer": "Trainer",
  "nodeloader_args": {
    "pickle_safe": false,
    "num_workers": 0,
    "prefetch_factor": 2,
    "filter_per_worker": false,
    "persistent_workers": false,
    "pin_memory": false
  }
}
