{
  "needs_sampler_in_fs": true,
  "feature_store": {
    "class_name": "Neo4jUDPFeatureStore",
    "connection_mode": "driver"
  },
  "graph_store": {
    "class_name": "Neo4SingleGS",
    "connection_mode": "driver"
  },
  "sampler": {
    "class_name": "Neo4jAggregationSampler",
    "max_neighbors": 10
  },
  "model": {
    "class_name": "MLPPostAggregation"
  },
  "trainer": "Trainer",
  "nodeloader_args": {
    "pickle_safe": false,
    "num_workers": 0,
    "prefetch_factor": 2,
    "filter_per_worker": false,
    "persistent_workers": false,
    "pin_memory": false
  }
}
