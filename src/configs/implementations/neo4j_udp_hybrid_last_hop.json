{
  "feature_store": {
    "class_name": "Neo4jUDPFeatureStore",
    "connection_mode": "driver",
    "extra_kwargs": {
      "aggregation_mode": "sampledGcnNorm"
    }
  },
  "graph_store": {
    "class_name": "Neo4jSingleGS",
    "connection_mode": "driver"
  },
  "sampler": {
    "class_name": "Neo4jJavaNeighborSampler",
    "num_neighbors": [10, 5]
  },
  "model": {
    "class_name": "GCN",
    "to_hybrid_last_hop_preaggregation": true
  },
  "trainer": "Trainer",
  "nodeloader_args": {
    "pickle_safe": false,
    "num_workers": 0,
    "prefetch_factor": 2,
    "filter_per_worker": false,
    "persistent_workers": false,
    "pin_memory": false
  }
}