{
  "feature_store": {
    "class_name": "Neo4jNoCacheFS",
    "connection_mode": "uri"
  },
  "graph_store": {
    "class_name": "Neo4jMultiGS",
    "connection_mode": "uri"
  },
  "sampler": {
    "class_name": "Neo4jNeighborSampler",
    "num_neighbors": [10, 5]
  },
  "model": {
    "class_name": "GCN"
  },
  "trainer": "Trainer",
  "nodeloader_args": {
    "pickle_safe": true,
    "num_workers": 4,
    "prefetch_factor": 3,
    "filter_per_worker": true,
    "persistent_workers": true,
    "pin_memory": false
  }
}
