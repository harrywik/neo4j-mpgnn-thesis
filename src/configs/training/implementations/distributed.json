{
  "_comment": "DEPRECATED — Distributed Data Parallel training. Requires torchrun + NCCL + GPU.",
  "feature_store": {
    "class_name": "PickleSafeFeatureStore",
    "connection_mode": "uri"
  },
  "graph_store": {
    "class_name": "PickleSafeGS",
    "connection_mode": "uri"
  },
  "sampler": {
    "class_name": "UniformSampler",
    "num_neighbors": [10, 5]
  },
  "model": {
    "class_name": "GCN"
  },
  "trainer": "DistributedTrainer",
