{
  "_comment": "Distributed Data Parallel training. Works on CPU (gloo) and GPU (nccl).",
  "feature_store": {
    "class_name": "Neo4jFS",
    "connection_mode": "uri"
  },
  "graph_store": {
    "class_name": "Neo4jMultiGS",
    "connection_mode": "uri"
  },
  "sampler": {
    "class_name": "Neo4jSampler",
    "num_neighbors": [10, 5]
  },
  "model": {
    "class_name": "GCN"
  },
  "trainer": "DistributedTrainer",
  "nodeloader_args": {
    "pickle_safe": true,
    "num_workers": 2,
    "prefetch_factor": 2,
    "filter_per_worker": false,
    "persistent_workers": true,
    "pin_memory": false
  }
}
