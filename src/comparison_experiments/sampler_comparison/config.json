{
  "profile": false,
  "num_runs": 1,
  "max_epochs": 10,
  "batch_size": 30,
  "num_neighbors": [10, 5],
  "lr": 1e-3,
  "patience": 200,
  "min_delta": 0.01,
  "shuffle": true,
  "drop_last": true,
  "initialise_weights": true,
  "hidden_dim1": 12,
  "hidden_dim2": 12,
  "neo4j_edge_mode": "incoming",
  "graphsaint_batch_size": 1000,
  "walk_length": 2,
  "num_steps": 5,
  "sample_coverage": 200,
  "samplers": [
    "Neo4jGraphSAINTRandomWalkSampler",
    "Neo4jSampler" 
  ]
}
